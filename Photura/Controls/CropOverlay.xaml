<UserControl x:Class="Photura.Controls.CropOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Canvas x:Name="RootCanvas"
            Background="Transparent"
            MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
            MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
            MouseMove="Canvas_MouseMove"
            MouseRightButtonDown="Canvas_MouseRightButtonDown">

        <!-- Dark overlay: Top, Bottom, Left, Right -->
        <Rectangle x:Name="OverlayTop"    Fill="{DynamicResource OverlayBrush}" IsHitTestVisible="False"/>
        <Rectangle x:Name="OverlayBottom" Fill="{DynamicResource OverlayBrush}" IsHitTestVisible="False"/>
        <Rectangle x:Name="OverlayLeft"   Fill="{DynamicResource OverlayBrush}" IsHitTestVisible="False"/>
        <Rectangle x:Name="OverlayRight"  Fill="{DynamicResource OverlayBrush}" IsHitTestVisible="False"/>

        <!-- Crop border -->
        <Rectangle x:Name="CropBorder"
                   Stroke="White" StrokeThickness="1.5"
                   StrokeDashArray="5,3"
                   Fill="Transparent"
                   IsHitTestVisible="False"/>

        <!-- Rule of thirds grid lines -->
        <Line x:Name="GridH1" Stroke="#66FFFFFF" StrokeThickness="1" IsHitTestVisible="False"/>
        <Line x:Name="GridH2" Stroke="#66FFFFFF" StrokeThickness="1" IsHitTestVisible="False"/>
        <Line x:Name="GridV1" Stroke="#66FFFFFF" StrokeThickness="1" IsHitTestVisible="False"/>
        <Line x:Name="GridV2" Stroke="#66FFFFFF" StrokeThickness="1" IsHitTestVisible="False"/>

        <!-- Resize handles -->
        <Rectangle x:Name="HandleTL" Width="10" Height="10" RadiusX="2" RadiusY="2"
                   Fill="White" Stroke="#FF4FC3F7" StrokeThickness="1.5" Cursor="SizeNWSE"/>
        <Rectangle x:Name="HandleTC" Width="10" Height="10" RadiusX="2" RadiusY="2"
                   Fill="White" Stroke="#FF4FC3F7" StrokeThickness="1.5" Cursor="SizeNS"/>
        <Rectangle x:Name="HandleTR" Width="10" Height="10" RadiusX="2" RadiusY="2"
                   Fill="White" Stroke="#FF4FC3F7" StrokeThickness="1.5" Cursor="SizeNESW"/>
        <Rectangle x:Name="HandleML" Width="10" Height="10" RadiusX="2" RadiusY="2"
                   Fill="White" Stroke="#FF4FC3F7" StrokeThickness="1.5" Cursor="SizeWE"/>
        <Rectangle x:Name="HandleMR" Width="10" Height="10" RadiusX="2" RadiusY="2"
                   Fill="White" Stroke="#FF4FC3F7" StrokeThickness="1.5" Cursor="SizeWE"/>
        <Rectangle x:Name="HandleBL" Width="10" Height="10" RadiusX="2" RadiusY="2"
                   Fill="White" Stroke="#FF4FC3F7" StrokeThickness="1.5" Cursor="SizeNESW"/>
        <Rectangle x:Name="HandleBC" Width="10" Height="10" RadiusX="2" RadiusY="2"
                   Fill="White" Stroke="#FF4FC3F7" StrokeThickness="1.5" Cursor="SizeNS"/>
        <Rectangle x:Name="HandleBR" Width="10" Height="10" RadiusX="2" RadiusY="2"
                   Fill="White" Stroke="#FF4FC3F7" StrokeThickness="1.5" Cursor="SizeNWSE"/>

    </Canvas>
</UserControl>