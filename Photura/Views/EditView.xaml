<Window x:Class="Photura.Views.EditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Photura.Controls"
        xmlns:scenes="clr-namespace:Photura.Views.Scenes"
        Title="Photura — Edit"
        Height="850" Width="1200"
        MinHeight="500" MinWidth="700"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        WindowStartupLocation="CenterScreen"
        PreviewMouseWheel="Window_PreviewMouseWheel"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== TOP BAR ===== -->
        <Border Grid.Row="0"
                Background="{DynamicResource ToolbarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{DynamicResource ToolButtonStyle}"
                        Click="Done_Click"
                        ToolTip="Return to viewer without saving">
                    ← Done
                </Button>

                <TextBlock Grid.Column="1"
                           x:Name="FileNameLabel" Text=""
                           FontSize="14" FontFamily="Segoe UI" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">

                    <!-- Resampling indicator -->
                    <TextBlock x:Name="ResamplingLabel"
                               Text="Processing…"
                               FontSize="12" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Visibility="Collapsed"/>

                    <TextBlock x:Name="SavingLabel"
                                Text="Saving…"
                                FontSize="12" FontFamily="Segoe UI"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0"
                                Visibility="Collapsed"/>

                    <!-- Compare toggle -->
                    <Button x:Name="CompareBtn"
                        Style="{DynamicResource ToolButtonStyle}"
                        Margin="0,0,8,0"
                        ToolTip="Hold to compare with original"
                        PreviewMouseLeftButtonDown="CompareBtn_MouseDown"
                        PreviewMouseLeftButtonUp="CompareBtn_MouseUp">
                        👁  Original
                    </Button>

                    <Button Style="{DynamicResource ToolButtonStyle}"
                            Command="{Binding SaveAsCommand}"
                            Margin="0,0,8,0">
                        Save As
                    </Button>
                    <Button Style="{DynamicResource AccentButtonStyle}"
                            Command="{Binding SaveCommand}">
                        💾  Save
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== SCENE TABS ===== -->
        <Border Grid.Row="1"
                Background="{DynamicResource ToolbarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <RadioButton x:Name="CropTab" Content="Crop"
                             Style="{DynamicResource SceneTabStyle}"
                             IsChecked="True" Checked="SceneTab_Checked"/>
                <RadioButton x:Name="AdjustTab" Content="Adjustments"
                             Style="{DynamicResource SceneTabStyle}"
                             Checked="SceneTab_Checked"/>
                <RadioButton x:Name="FilterTab" Content="Filters"
                             Style="{DynamicResource SceneTabStyle}"
                             Checked="SceneTab_Checked"/>
            </StackPanel>
        </Border>

        <!-- ===== MAIN AREA ===== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    x:Name="CanvasBorder"
                    Background="{DynamicResource BackgroundBrush}"
                    ClipToBounds="True"
                    SizeChanged="CanvasBorder_SizeChanged">
                <Canvas x:Name="ImageCanvas"
                        Background="Transparent"
                        MouseDown="ImageCanvas_MouseDown"
                        MouseUp="ImageCanvas_MouseUp"
                        MouseMove="ImageCanvas_MouseMove">
                    <Image x:Name="MainImage"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Stretch="None">
                        <Image.LayoutTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                                <RotateTransform x:Name="ImageRotation" Angle="0"/>
                            </TransformGroup>
                        </Image.LayoutTransform>
                    </Image>
                    <controls:CropOverlay x:Name="CropOverlayControl"
                                          CropChanged="CropOverlay_CropChanged"/>
                </Canvas>
            </Border>

            <Border Grid.Column="1"
                    Background="{DynamicResource ScenePanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <scenes:CropScene x:Name="CropScenePanel" Visibility="Visible"/>
                    <scenes:AdjustmentsScene x:Name="AdjustScenePanel"
                                             Visibility="Collapsed"
                                             AdjustmentChanged="AdjustScene_Changed"/>
                    <scenes:FiltersScene x:Name="FilterScenePanel"
                                         Visibility="Collapsed"
                                         FilterSelected="FilterScene_Selected"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== BOTTOM BAR ===== -->
        <Border Grid.Row="3"
                Background="{DynamicResource ToolbarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           x:Name="CropInfoLabel" Text=""
                           FontSize="11" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{DynamicResource ToolButtonStyle}"
                            Click="ZoomOut_Click"
                            Padding="8,4" FontSize="16" Margin="0,0,4,0">−</Button>
                    <Slider x:Name="ZoomSlider" Width="100"
                            Minimum="5" Maximum="800" Value="100"
                            Style="{DynamicResource EditSliderStyle}"
                            VerticalAlignment="Center"
                            ValueChanged="ZoomSlider_ValueChanged"/>
                    <Button Style="{DynamicResource ToolButtonStyle}"
                            Click="ZoomIn_Click"
                            Padding="8,4" FontSize="16" Margin="4,0">+</Button>
                    <TextBlock x:Name="ZoomLabel" Text="100%"
                               Width="45" TextAlignment="Center"
                               FontSize="12" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <Button Style="{DynamicResource ToolButtonStyle}"
                            Click="ZoomFit_Click" Padding="8,4" Margin="4,0,0,0">
                        Fit
                    </Button>
                    <Button Style="{DynamicResource ToolButtonStyle}"
                            Click="Zoom100_Click" Padding="8,4" Margin="4,0,0,0">
                        100%
                    </Button>
                </StackPanel>

                <TextBlock Grid.Column="2"
                           x:Name="ImageSizeLabel" Text=""
                           FontSize="11" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>