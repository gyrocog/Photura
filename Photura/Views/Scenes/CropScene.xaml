<UserControl x:Class="Photura.Views.Scenes.CropScene"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
        <StackPanel Margin="16,16,16,16">

            <!-- Crop size info -->
            <TextBlock Text="CROP SIZE"
                       FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,8"/>
            <TextBlock x:Name="CropSizeLabel"
                       Text="—"
                       FontSize="20" FontWeight="SemiBold" FontFamily="Segoe UI"
                       Foreground="{DynamicResource AccentBrush}"
                       Margin="0,0,0,4"/>
            <TextBlock x:Name="CropPositionLabel"
                       Text=""
                       FontSize="11" FontFamily="Segoe UI"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,16"/>

            <Separator Style="{DynamicResource PanelSeparatorStyle}"/>

            <!-- Aspect ratio -->
            <TextBlock Text="ASPECT RATIO"
                       FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,10"/>
            <WrapPanel x:Name="AspectPanel" Margin="0,0,0,16"/>

            <Separator Style="{DynamicResource PanelSeparatorStyle}"/>

            <!-- Image resize -->
            <TextBlock Text="IMAGE SIZE"
                       FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,6"/>
            <TextBlock Text="Resize image inside crop area"
                       FontSize="11" FontFamily="Segoe UI"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,10" TextWrapping="Wrap"/>
            <UniformGrid Columns="3" Margin="0,0,0,16">
                <Button Style="{DynamicResource ToolButtonStyle}"
                        Margin="0,0,4,0" Padding="6,6"
                        Click="ShrinkLarge_Click"
                        ToolTip="Shrink image by 20%">
                    −−
                </Button>
                <Button Style="{DynamicResource ToolButtonStyle}"
                        Margin="2,0" Padding="6,6"
                        Click="Shrink_Click"
                        ToolTip="Shrink image by 5%">
                    −
                </Button>
                <Button Style="{DynamicResource ToolButtonStyle}"
                        Margin="4,0,0,0" Padding="6,6"
                        Click="FitImage_Click"
                        ToolTip="Fit image to crop area">
                    Fit
                </Button>
            </UniformGrid>
            <UniformGrid Columns="2" Margin="0,0,0,16">
                <Button Style="{DynamicResource ToolButtonStyle}"
                        Margin="0,0,4,0" Padding="6,6"
                        Click="Enlarge_Click"
                        ToolTip="Enlarge image by 5%">
                    +
                </Button>
                <Button Style="{DynamicResource ToolButtonStyle}"
                        Margin="4,0,0,0" Padding="6,6"
                        Click="EnlargeLarge_Click"
                        ToolTip="Enlarge image by 20%">
                    ++
                </Button>
            </UniformGrid>

            <Separator Style="{DynamicResource PanelSeparatorStyle}"/>

            <!-- Rotation -->
            <TextBlock Text="STRAIGHTEN"
                       FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,10"/>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Angle"
                           FontSize="12" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" x:Name="RotationValueLabel"
                           Text="0°"
                           FontSize="12" FontFamily="Segoe UI" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}"/>
            </Grid>
            <Slider x:Name="RotationSlider"
                    Minimum="-45" Maximum="45" Value="0"
                    Style="{DynamicResource EditSliderStyle}"
                    Margin="0,0,0,4"
                    ValueChanged="RotationSlider_ValueChanged"
                    PreviewMouseWheel="RotationSlider_MouseWheel"/>
            <TextBlock Text="Double-click slider to reset"
                       FontSize="10" FontFamily="Segoe UI"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,16"/>

            <Separator Style="{DynamicResource PanelSeparatorStyle}"/>

            <!-- Rotate / Flip -->
            <TextBlock Text="ROTATE &amp; FLIP"
                       FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,10"/>
            <UniformGrid Columns="2" Margin="0,0,0,8">
                <Button Style="{DynamicResource ToolButtonStyle}"
                        Margin="0,0,4,4" Command="{Binding RotateCCWCommand}">
                    ↺  Rotate Left
                </Button>
                <Button Style="{DynamicResource ToolButtonStyle}"
                        Margin="4,0,0,4" Command="{Binding RotateCWCommand}">
                    ↻  Rotate Right
                </Button>
            </UniformGrid>
            <UniformGrid Columns="2">
                <Button Style="{DynamicResource ToolButtonStyle}"
                        Margin="0,0,4,0" Command="{Binding FlipHCommand}">
                    ⇄  Flip H
                </Button>
                <Button Style="{DynamicResource ToolButtonStyle}"
                        Margin="4,0,0,0" Command="{Binding FlipVCommand}">
                    ⇅  Flip V
                </Button>
            </UniformGrid>

            <Separator Style="{DynamicResource PanelSeparatorStyle}"/>

            <!-- Reset -->
            <Button Style="{DynamicResource ToolButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Command="{Binding ResetCommand}">
                ⟳  Reset All
            </Button>

        </StackPanel>
    </ScrollViewer>
</UserControl>