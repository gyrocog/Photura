<Window x:Class="Photura.Views.ViewerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Photura"
        Height="850" Width="1200"
        MinHeight="500" MinWidth="700"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        PreviewMouseWheel="Window_PreviewMouseWheel"
        KeyDown="Window_KeyDown"
        SizeChanged="Window_SizeChanged"
        StateChanged="Window_StateChanged">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Loading indicator -->
        <Border x:Name="LoadingOverlay"
        Background="#88000000"
        Visibility="{Binding IsLoading,
            Converter={StaticResource BoolToVisConverter}}"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        CornerRadius="8"
        Padding="20,12">
            <TextBlock Text="Loading…"
               Foreground="White"
               FontSize="14" FontFamily="Segoe UI"/>
        </Border>

        <!-- ===== TOP BAR ===== -->
        <Border Grid.Row="0"
                Background="{DynamicResource ToolbarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Style="{DynamicResource ToolButtonStyle}"
                            Click="Open_Click" Margin="0,0,4,0"
                            ToolTip="Open image (Ctrl+O)">
                        📂  Open
                    </Button>
                    <Button Style="{DynamicResource ToolButtonStyle}"
                            Command="{Binding CopyCommand}"
                            Margin="0,0,4,0"
                            ToolTip="Copy image to clipboard (Ctrl+C)">
                        📋  Copy
                    </Button>
                    <Button Style="{DynamicResource ToolButtonStyle}"
                            Command="{Binding DeleteCommand}"
                            ToolTip="Delete image (Del)">
                        🗑  Delete
                    </Button>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           x:Name="FileNameLabel" Text="Photura"
                           FontSize="14" FontFamily="Segoe UI" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Style="{DynamicResource AccentButtonStyle}"
                            Command="{Binding EditCommand}"
                            Margin="0,0,12,0">
                        ✏️  Edit
                    </Button>
                    <ToggleButton x:Name="ThemeToggle"
                                  Style="{DynamicResource ToggleButtonStyle}"
                                  Checked="ThemeToggle_Checked"
                                  Unchecked="ThemeToggle_Unchecked"
                                  ToolTip="Switch theme">
                        🌙
                    </ToggleButton>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== IMAGE AREA ===== -->
        <Border Grid.Row="1"
                x:Name="ImageBorder"
                Background="{DynamicResource BackgroundBrush}"
                ClipToBounds="True"
                SizeChanged="ImageBorder_SizeChanged">

            <!-- Drop hint -->
            <Grid>
                <StackPanel x:Name="DropHint"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock Text="📷" FontSize="72"
                               HorizontalAlignment="Center" Opacity="0.2"/>
                    <TextBlock Text="Open an image or drag &amp; drop here"
                               FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,16,0,0" Opacity="0.5"/>
                    <TextBlock Text="Ctrl+O  ·  Scroll to navigate  ·  Ctrl+Scroll to zoom"
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,8,0,0" Opacity="0.35"/>
                </StackPanel>

                <!-- Canvas for image + panning, hidden until image loaded -->
                <Canvas x:Name="ImageCanvas"
                        Background="Transparent"
                        Visibility="Collapsed"
                        MouseDown="ImageCanvas_MouseDown"
                        MouseUp="ImageCanvas_MouseUp"
                        MouseMove="ImageCanvas_MouseMove">
                    <Image x:Name="MainImage"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Stretch="None">
                        <Image.LayoutTransform>
                            <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                        </Image.LayoutTransform>
                    </Image>
                </Canvas>

                <!-- Nav arrows on top of canvas -->
                <Button x:Name="PrevButton"
                        Style="{DynamicResource ToolButtonStyle}"
                        Command="{Binding PrevImageCommand}"
                        VerticalAlignment="Center" HorizontalAlignment="Left"
                        Margin="16,0" Padding="10,20" FontSize="20"
                        Visibility="Collapsed">‹</Button>
                <Button x:Name="NextButton"
                        Style="{DynamicResource ToolButtonStyle}"
                        Command="{Binding NextImageCommand}"
                        VerticalAlignment="Center" HorizontalAlignment="Right"
                        Margin="16,0" Padding="10,20" FontSize="20"
                        Visibility="Collapsed">›</Button>
            </Grid>
        </Border>

        <!-- ===== BOTTOM BAR ===== -->
        <Border Grid.Row="2"
                Background="{DynamicResource ToolbarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           x:Name="ImageInfoLabel" Text=""
                           FontSize="11" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{DynamicResource ToolButtonStyle}"
                            Click="ZoomOut_Click"
                            Padding="8,4" FontSize="16" Margin="0,0,4,0">−</Button>
                    <Slider x:Name="ZoomSlider" Width="120"
                            Minimum="5" Maximum="800" Value="100"
                            Style="{DynamicResource EditSliderStyle}"
                            VerticalAlignment="Center"
                            ValueChanged="ZoomSlider_ValueChanged"/>
                    <Button Style="{DynamicResource ToolButtonStyle}"
                            Click="ZoomIn_Click"
                            Padding="8,4" FontSize="16" Margin="4,0">+</Button>
                    <TextBlock x:Name="ZoomLabel" Text="100%"
                               Width="45" TextAlignment="Center"
                               FontSize="12" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <Button Style="{DynamicResource ToolButtonStyle}"
                            Click="ZoomFit_Click" Padding="8,4" Margin="4,0,0,0">
                        Fit
                    </Button>
                </StackPanel>

                <TextBlock Grid.Column="2"
                           x:Name="PositionLabel" Text=""
                           FontSize="11" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>